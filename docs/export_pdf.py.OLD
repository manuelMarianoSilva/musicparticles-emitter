#!/usr/bin/env python3
"""
export_pdf.py  —  Render architecture.json as a multi-page letter landscape PDF.

Usage:
    python3 export_pdf.py <config.json> [output.pdf]

If output path is omitted, writes <config-basename>.pdf next to the config.

Requirements:
    pip3 install reportlab          (or: pip3 install reportlab --target /tmp/pylibs_pdf)

Layout guarantee:
    Minimum rendered font size is 11pt.  The diagram is split across as many
    landscape letter pages as needed (3 for the default 7-column particle-system
    diagram).  Edges that cross page boundaries are drawn up to the page edge
    with a dashed line and a "→ pg N" continuation label.
"""

import json
import math
import re as _re
import sys
from pathlib import Path

# ── Bootstrap reportlab from /tmp/pylibs_pdf if not on sys.path ───────────────
try:
    from reportlab.pdfgen import canvas as _rl_canvas_mod
except ImportError:
    sys.path.insert(0, "/tmp/pylibs_pdf")
    from reportlab.pdfgen import canvas as _rl_canvas_mod  # noqa: F811

from reportlab.pdfgen import canvas as rlcanvas
from reportlab.lib.pagesizes import letter
from reportlab.lib.colors import HexColor, white, black, Color

# ── Page geometry (fixed) ─────────────────────────────────────────────────────
# Letter landscape: 11" × 8.5"  →  792pt × 612pt
PAGE_W, PAGE_H = letter[1], letter[0]   # swap for landscape
MARGIN         = 54    # 0.75-inch margin — keeps content in printer safe zone
HEADER_H       = 20    # height of the per-page title bar
FONT_HEADER    = 9     # page title font — not scaled

# ── Base layout constants (scale = 1.0) ───────────────────────────────────────
# _apply_scale() overwrites the un-prefixed names with k-scaled values.
_B_NW        = 110
_B_NH        = 55
_B_V_GAP     = 28
_B_SL_HDR    = 18
_B_NODE_PAD  = 8
_B_COL_GAP   = 100
_B_FONT_NODE = 11
_B_FONT_EDGE = 10
_B_FONT_BADGE  = 8
_B_TOP_CORR_H  = 60
_B_COL_STRIDE  = _B_NW + _B_NODE_PAD * 2 + _B_COL_GAP   # 226
# Gutter reserved on the LEFT of non-first pages so incoming corridor edges
# and their "← from pg N" markers have room without overlapping swimlanes.
_B_CONT_GUTTER = 160

# Working layout constants — set by _apply_scale() before rendering
NW = NH = V_GAP = SL_HDR = NODE_PAD = COL_GAP = 0
SL_W = COL_STRIDE = 0
FONT_NODE = FONT_LAYER = FONT_EDGE = FONT_BADGE = 0
TOP_CORR_H = CONT_GUTTER = 0
ARROW_LEN = ARROW_HALF = 0

def _apply_scale(k: float):
    """Scale all layout constants by k and update module globals."""
    global NW, NH, V_GAP, SL_HDR, NODE_PAD, COL_GAP
    global SL_W, COL_STRIDE
    global FONT_NODE, FONT_LAYER, FONT_EDGE, FONT_BADGE
    global TOP_CORR_H, CONT_GUTTER, ARROW_LEN, ARROW_HALF
    NW         = max(40, round(_B_NW        * k))
    NH         = max(20, round(_B_NH        * k))
    V_GAP      = max(8,  round(_B_V_GAP     * k))
    SL_HDR     = max(10, round(_B_SL_HDR    * k))
    NODE_PAD   = max(4,  round(_B_NODE_PAD  * k))
    COL_GAP    = max(20, round(_B_COL_GAP   * k))
    SL_W       = NW + NODE_PAD * 2
    COL_STRIDE = SL_W + COL_GAP
    FONT_NODE  = max(7,  round(_B_FONT_NODE * k))
    FONT_LAYER = FONT_NODE
    FONT_EDGE  = max(6,  round(_B_FONT_EDGE * k))
    FONT_BADGE = max(5,  round(_B_FONT_BADGE * k))
    TOP_CORR_H  = max(30, round(_B_TOP_CORR_H  * k))
    CONT_GUTTER = max(60, round(_B_CONT_GUTTER * k))
    ARROW_LEN   = max(4,  round(8 * k))
    ARROW_HALF  = max(2,  round(4 * k))

# ── Default colour palette (same cycle as generate_drawio.py) ────────────────
PALETTE = [
    ("dae8fc", "6c8ebf", "1a3a5c", "EBF5FB"),
    ("e1d5e7", "9673a6", "3d1a54", "F3EEF8"),
    ("d5e8d4", "82b366", "1a3d1a", "EBF7EB"),
    ("ffe6cc", "d6b656", "5c3a00", "FEF5E7"),
    ("f8cecc", "b85450", "6b1a17", "FDEDEC"),
    ("fff2cc", "a0a000", "3d3d00", "FEFDE7"),
    ("f5f5f5", "888888", "333333", "FAFAFA"),
    ("d0e8ff", "4a90d9", "0d3a6b", "E8F4FF"),
    ("e8f5e9", "388e3c", "1b5e20", "F1FAF1"),
    ("fce4ec", "e91e63", "880e4f", "FFF0F5"),
    ("fff3e0", "e65100", "5c3700", "FFF8F0"),
    ("e8eaf6", "3949ab", "1a237e", "F0F1FA"),
]

# ── Dead-code detection (mirrors generate_drawio.py) ─────────────────────────
_UNUSED_MARKERS = ("unused", "⚠", "dead code", "not used", "never called")

def _is_unused(node: dict) -> bool:
    raw = node.get("label", "")
    return bool(node.get("unused")) or any(m in raw.lower() for m in _UNUSED_MARKERS)

def _clean_label(raw: str) -> str:
    """Strip dead-code markers so the main text stays clean."""
    clean = raw
    for pat in (
        r"⚠\s*\w+\(\)\s*unused",
        r"⚠\s*[^\n]*",
        r"\bunused\b",
        r"\bdead\s*code\b",
        r"\bnot\s*used\b",
        r"\bnever\s*called\b",
    ):
        clean = _re.sub(pat, "", clean, flags=_re.IGNORECASE)
    lines = [l.strip() for l in clean.replace("\\n", "\n").split("\n")]
    return "\n".join(l for l in lines if l)

# ── Colour helpers ────────────────────────────────────────────────────────────
def _hex(h: str) -> HexColor:
    return HexColor(f"#{h}")

# ── Layout computation ────────────────────────────────────────────────────────
def compute_layout(cfg: dict):
    """Return positions and geometry in PDF points.

    abs_pos[node_id]       = (x, y)  top-left of node on the infinite canvas
    swimlane_geom[lid]     = (x, y, w, h)  of the swimlane container
    node_to_layer[node_id] = layer_id
    col_of[layer_id]       = column index
    layer_nodes[layer_id]  = [node_id, ...]
    layer_meta[layer_id]   = theme dict
    """
    abs_pos       = {}
    swimlane_geom = {}
    node_to_layer = {}
    col_of        = {}
    layer_nodes   = {}
    layer_meta    = {}

    for col_idx, layer in enumerate(cfg["layers"]):
        lid   = layer["id"]
        nodes = layer.get("nodes", [])
        n     = len(nodes)

        col_of[lid]      = col_idx
        layer_nodes[lid] = [nd["id"] for nd in nodes]

        # Assign palette colour
        fill, stroke, font, group = PALETTE[col_idx % len(PALETTE)]
        t = dict(layer.get("theme", {}))
        t.setdefault("fill",   fill)
        t.setdefault("stroke", stroke)
        t.setdefault("font",   font)
        t.setdefault("group",  group)
        layer_meta[lid] = t

        sl_x = col_idx * COL_STRIDE
        sl_y = 0
        sl_h = SL_HDR + NODE_PAD + n * NH + max(0, n - 1) * V_GAP + NODE_PAD

        swimlane_geom[lid] = (sl_x, sl_y, SL_W, sl_h)

        for row_idx, node in enumerate(nodes):
            nid = node["id"]
            nx  = sl_x + NODE_PAD
            ny  = SL_HDR + NODE_PAD + row_idx * (NH + V_GAP)
            abs_pos[nid] = (nx, ny)
            node_to_layer[nid] = lid

    return abs_pos, swimlane_geom, node_to_layer, col_of, layer_nodes, layer_meta

# ── Geometry helpers (canvas-space, top-left origin) ─────────────────────────
def _cx(pos, nid): return pos[nid][0] + NW / 2
def _cy(pos, nid): return pos[nid][1] + NH / 2
def _lft(pos, nid): return pos[nid][0]
def _rgt(pos, nid): return pos[nid][0] + NW
def _top(pos, nid): return pos[nid][1]
def _bot(pos, nid): return pos[nid][1] + NH

def _gap_mid(col_idx: int) -> float:
    right_edge = col_idx * COL_STRIDE + SL_W
    left_next  = (col_idx + 1) * COL_STRIDE
    return (right_edge + left_next) / 2

def _left_gap_mid(col_idx: int) -> float:
    if col_idx == 0:
        return -COL_GAP / 2
    return _gap_mid(col_idx - 1)

# ── Edge routing (geometry only — mirrors generate_drawio.py logic) ───────────

# Stagger state for skip-row same-column edges (reset per layout call)
_skip_r_state: dict = {}
_up_l_state:   dict = {}

def _estimate_label_px_pdf(text: str, char_w: float = 6.0) -> float:
    if not text:
        return 0
    longest = max(len(l) for l in text.replace("\\n", "\n").split("\n"))
    return longest * char_w

def _max_col_bottom(abs_pos, node_to_layer, col_of, layer_nodes, c_min, c_max):
    """Return the lowest y-bottom across ALL nodes in columns c_min..c_max."""
    bottoms = []
    for lid, col in col_of.items():
        if c_min <= col <= c_max:
            for nid in layer_nodes[lid]:
                bottoms.append(_bot(abs_pos, nid))
    return max(bottoms) if bottoms else 0

def compute_routing(src, dst, abs_pos, node_to_layer, col_of, layer_nodes,
                    label="", vert_offset=0.0):
    """Returns list of (x, y) points describing the full edge polyline
    (source centre → ... → target centre).

    Routing strategy — mirrors the draw.io output:
      • Adjacent-column forward  : L-shape through the inter-column gap.
      • Multi-column forward      : TOP corridor (canvas y = Y_TOP, which sits in
                                    the reserved TOP_CORR_H space above swimlanes).
      • Adjacent-column backward  : reverse L-shape through the shared gap.
      • Multi-column backward     : top corridor (right-to-left).
      • Same-column skip-down     : right-side gap bypass (staggered per label).
      • Same-column skip-up       : left-side gap bypass (staggered per label).

    Y_TOP is negative in canvas space (above the swimlane tops at y=0) but maps
    to a valid PDF y that lies between the page-header divider and the swimlane
    tops, because diagram_top is pushed down by TOP_CORR_H in _render_page.
    """
    sc      = col_of[node_to_layer[src]]
    dc      = col_of[node_to_layer[dst]]
    src_row = layer_nodes[node_to_layer[src]].index(src)
    dst_row = layer_nodes[node_to_layer[dst]].index(dst)

    # Edge entry/exit points — ALL routes start and end on the node BOUNDARY,
    # never at the centre.  This prevents the visual artefact of lines appearing
    # to originate from inside a node.
    # vert_offset (canvas units) shifts both ends vertically to separate
    # bidirectional parallel edges that would otherwise overlap.
    src_cy = _cy(abs_pos, src) + vert_offset
    dst_cy = _cy(abs_pos, dst) + vert_offset

    # Top corridor: placed at 2/3 of the corridor height so that labels have
    # room both above (to header rule) and below (to swimlane top).
    Y_TOP = -(TOP_CORR_H * 2 // 3)

    if sc < dc:
        # Forward edges exit from the RIGHT edge of src, enter LEFT edge of dst.
        sx = _rgt(abs_pos, src)
        dx = _lft(abs_pos, dst)

        if dc - sc == 1:
            # Adjacent columns: L-shape through the inter-column gap
            if src_cy == dst_cy:
                return [(sx, src_cy), (dx, dst_cy)]
            gx = _gap_mid(sc)
            return [(sx, src_cy), (gx, src_cy), (gx, dst_cy), (dx, dst_cy)]

        # Multi-column forward: exit right → rise to top corridor → cross →
        # descend to destination gap → enter left edge of dst.
        g_src = _gap_mid(sc)
        g_dst = _gap_mid(dc - 1)
        pts   = [(sx, src_cy), (g_src, src_cy), (g_src, Y_TOP)]
        if g_src != g_dst:
            pts.append((g_dst, Y_TOP))
        pts += [(g_dst, dst_cy), (dx, dst_cy)]
        return pts

    if sc > dc:
        # Backward edges exit from the LEFT edge of src, enter RIGHT edge of dst.
        sx = _lft(abs_pos, src)
        dx = _rgt(abs_pos, dst)

        if sc - dc == 1:
            # Adjacent-column backward: reverse L through the shared gap
            gx = _gap_mid(dc)
            if src_cy == dst_cy:
                return [(sx, src_cy), (gx, src_cy), (dx, dst_cy)]
            return [(sx, src_cy), (gx, src_cy), (gx, dst_cy), (dx, dst_cy)]

        # Multi-column backward: exit left → rise to top corridor → cross left →
        # descend to destination gap → enter right edge of dst.
        g_src = _gap_mid(sc - 1)
        g_dst = _gap_mid(dc)
        pts   = [(sx, src_cy), (g_src, src_cy), (g_src, Y_TOP)]
        if g_src != g_dst:
            pts.append((g_dst, Y_TOP))
        pts += [(g_dst, dst_cy), (dx, dst_cy)]
        return pts

    # Same column — vertical connections use top/bottom boundaries.
    if src_row == dst_row:
        return [(_cx(abs_pos, src), src_cy), (_cx(abs_pos, dst), dst_cy)]

    if src_row < dst_row:
        if dst_row - src_row == 1:
            # Adjacent rows: straight vertical between node boundaries
            return [(_cx(abs_pos, src), _bot(abs_pos, src)),
                    (_cx(abs_pos, dst), _top(abs_pos, dst))]
        # Skip rows: right-side gap bypass, staggered per label
        key  = f"skip_{sc}"
        step = _estimate_label_px_pdf(label) / 2 + 8
        off  = _skip_r_state.get(key, 0)
        _skip_r_state[key] = off + step
        rx = _gap_mid(sc) + off
        return [(_rgt(abs_pos, src), src_cy), (rx, src_cy),
                (rx, dst_cy), (_rgt(abs_pos, dst), dst_cy)]
    else:
        # Upward same column: left-side gap bypass, staggered per label
        key  = f"up_{sc}"
        step = _estimate_label_px_pdf(label) / 2 + 8
        off  = _up_l_state.get(key, 0)
        _up_l_state[key] = off + step
        lx = _left_gap_mid(sc) - off
        return [(_lft(abs_pos, src), src_cy), (lx, src_cy),
                (lx, dst_cy), (_lft(abs_pos, dst), dst_cy)]

# ── PDF coordinate conversion ─────────────────────────────────────────────────
# ReportLab's origin is bottom-left; our canvas is top-left.
# page_top is the y coordinate (in PDF points) of the top of the diagram area.
def _pdf_xy(cx: float, cy: float, page_col0: int, page_top: float):
    """Convert canvas (x, y) → PDF (x, y) for the current page.

    page_col0 : index of the leftmost column on this page
    page_top  : PDF y of the top of the diagram area
    """
    px = MARGIN + (cx - page_col0 * COL_STRIDE)
    py = page_top - cy
    return px, py

# ── Drawing primitives ────────────────────────────────────────────────────────

def _draw_rounded_rect(c, x, y, w, h, r, fill_color, stroke_color,
                        stroke_width=0.5, fill=True, stroke=True):
    """x, y is bottom-left in PDF coords."""
    c.setFillColor(fill_color)
    c.setStrokeColor(stroke_color)
    c.setLineWidth(stroke_width)
    c.roundRect(x, y, w, h, r, fill=int(fill), stroke=int(stroke))

def _draw_text_block(c, lines, cx, cy, font, font_size, color, bold=False):
    """Draw multi-line text centred at (cx, cy) in PDF coords."""
    c.setFillColor(color)
    face = "Helvetica-Bold" if bold else "Helvetica"
    c.setFont(face, font_size)
    lh      = font_size * 1.25
    total_h = len(lines) * lh
    start_y = cy + total_h / 2 - lh * 0.85
    for i, line in enumerate(lines):
        c.drawCentredString(cx, start_y - i * lh, line)


def _fit_text_in_box(c, lines, cx, cy, avail_w, avail_h,
                     base_font, color, bold=True, min_font=5.5):
    """Draw multi-line text centred at (cx, cy), shrinking font until it fits.

    If even at min_font a line is too wide, the line is truncated with '…'.
    If there are more lines than fit vertically, excess lines are dropped.
    """
    face = "Helvetica-Bold" if bold else "Helvetica"

    # Step 1: find a font size where every line fits horizontally
    fs = float(base_font)
    while fs >= min_font:
        c.setFont(face, fs)
        if all(c.stringWidth(l, face, fs) <= avail_w for l in lines):
            break
        fs = round(fs - 0.5, 1)

    # Step 2: if still too wide at min_font, truncate each offending line
    if fs < min_font:
        fs = min_font
        c.setFont(face, fs)
        fitted = []
        for line in lines:
            if c.stringWidth(line, face, fs) <= avail_w:
                fitted.append(line)
            else:
                # shorten until it fits with an ellipsis
                short = line
                while short and c.stringWidth(short + "…", face, fs) > avail_w:
                    short = short[:-1]
                fitted.append((short + "…") if short else "…")
        lines = fitted

    # Step 3: drop lines that exceed the vertical space
    lh       = fs * 1.25
    max_lines = max(1, int(avail_h / lh))
    lines     = lines[:max_lines]

    _draw_text_block(c, lines, cx, cy, None, fs, color, bold=bold)

def _arrowhead(c, x0, y0, x1, y1, color):
    """Draw a filled arrowhead at (x1, y1) pointing from (x0, y0)."""
    dx = x1 - x0
    dy = y1 - y0
    length = math.hypot(dx, dy)
    if length < 1:
        return
    ux, uy = dx / length, dy / length
    px, py = -uy, ux    # perpendicular

    tip  = (x1, y1)
    base_cx = x1 - ux * ARROW_LEN
    bl   = (base_cx + px * ARROW_HALF, y1 - uy * ARROW_LEN + py * ARROW_HALF)
    br   = (base_cx - px * ARROW_HALF, y1 - uy * ARROW_LEN - py * ARROW_HALF)

    c.setFillColor(color)
    p = c.beginPath()
    p.moveTo(*tip)
    p.lineTo(*bl)
    p.lineTo(*br)
    p.close()
    c.drawPath(p, fill=1, stroke=0)

def _draw_polyline(c, points, color, width=0.75, dashed=False):
    """Draw a polyline through PDF-space points."""
    if len(points) < 2:
        return
    c.setStrokeColor(color)
    c.setLineWidth(width)
    if dashed:
        c.setDash(4, 3)
    else:
        c.setDash()
    p = c.beginPath()
    p.moveTo(*points[0])
    for pt in points[1:]:
        p.lineTo(*pt)
    c.drawPath(p, fill=0, stroke=1)
    c.setDash()

# ── Per-page rendering ────────────────────────────────────────────────────────

def _render_page(c, cfg, page_idx, page_groups, abs_pos, swimlane_geom,
                 node_to_layer, col_of, layer_nodes, layer_meta, x_offset=0):
    """Render one landscape-letter page.

    x_offset > 0 reserves a left gutter for incoming cross-page edge
    continuations.  Swimlanes and all diagram content are shifted right by
    x_offset, while the gutter zone [MARGIN, MARGIN+x_offset] shows the
    incoming dashed trails and "← from pg N" markers.
    """
    title     = cfg.get("title", "Architecture")
    n_pages   = len(page_groups)
    cols      = page_groups[page_idx]
    col0      = cols[0]

    # Layers on this page (preserve config order)
    page_layers = [l for l in cfg["layers"] if col_of[l["id"]] in cols]

    # PDF y of canvas origin (canvas y=0 = swimlane tops).
    # TOP_CORR_H pt are reserved above this for the top corridor, between the
    # swimlane tops and the page-header divider line.
    diagram_top = PAGE_H - MARGIN - HEADER_H - 4 - TOP_CORR_H

    # Local coordinate helper that applies the gutter x_offset so all diagram
    # content is shifted right on non-first pages.
    def _pxy(cx, cy):
        return (MARGIN + x_offset + (cx - col0 * COL_STRIDE),
                diagram_top - cy)

    # ── Page header ──────────────────────────────────────────────────────────
    c.setFillColor(HexColor("#333333"))
    c.setFont("Helvetica-Bold", FONT_HEADER)
    c.drawString(MARGIN, PAGE_H - MARGIN - FONT_HEADER + 2, title)
    c.setFont("Helvetica", FONT_HEADER)
    page_str = f"Page {page_idx + 1} of {n_pages}"
    c.drawRightString(PAGE_W - MARGIN, PAGE_H - MARGIN - FONT_HEADER + 2, page_str)
    c.setStrokeColor(HexColor("#cccccc"))
    c.setLineWidth(0.5)
    c.line(MARGIN, PAGE_H - MARGIN - HEADER_H + 2,
           PAGE_W - MARGIN, PAGE_H - MARGIN - HEADER_H + 2)

    # ── Gutter: subtle separator between continuation zone and diagram ───────────
    # Incoming cross-page edges are already drawn correctly by the main edge
    # loop (left_clip = MARGIN allows their continuation segments into the gutter
    # zone).  We only need the vertical hairline that visually marks the boundary
    # between the gutter and the start of the swimlanes.
    if x_offset > 0:
        c.setStrokeColor(HexColor("#dddddd"))
        c.setLineWidth(0.5)
        c.setDash(2, 4)
        c.line(MARGIN + x_offset, diagram_top + TOP_CORR_H - 6,
               MARGIN + x_offset, diagram_top - 8)
        c.setDash()

    # ── Swimlane backgrounds ─────────────────────────────────────────────────
    for layer in page_layers:
        lid = layer["id"]
        t   = layer_meta[lid]
        lx, ly, lw, lh = swimlane_geom[lid]
        px, py = _pxy(lx, ly)
        # py is PDF y of top of swimlane; reportlab wants bottom-left
        _draw_rounded_rect(c, px, py - lh, lw, lh, 4,
                           _hex(t["group"]), _hex(t["stroke"]),
                           stroke_width=1.5)
        # Layer name in header
        c.setFillColor(_hex(t["stroke"]))
        c.setFont("Helvetica-Bold", FONT_LAYER)
        hdr_cy = py - SL_HDR / 2
        c.drawCentredString(px + lw / 2, hdr_cy - FONT_LAYER * 0.35,
                            layer.get("label", layer["id"]))

    # ── Nodes ────────────────────────────────────────────────────────────────
    _UNUSED_MARKERS_SET = set(_UNUSED_MARKERS)
    for layer in page_layers:
        lid = layer["id"]
        t   = layer_meta[lid]
        for node in layer.get("nodes", []):
            nid   = node["id"]
            is_u  = _is_unused(node)
            nx, ny = abs_pos[nid]
            px, py = _pxy(nx, ny)
            # py = PDF y of top-left of node → bottom-left for reportlab
            stroke_col = HexColor("#FF0000") if is_u else _hex(t["stroke"])
            stroke_w   = 2.0 if is_u else 0.75
            _draw_rounded_rect(c, px, py - NH, NW, NH, 5,
                               _hex(t["fill"]), stroke_col,
                               stroke_width=stroke_w)

            raw_label = node.get("label", node["id"])
            if is_u:
                display = _clean_label(raw_label)
            else:
                display = raw_label.replace("\\n", "\n")
            lines   = [l for l in display.split("\n") if l.strip()]
            node_cy = py - NH / 2          # PDF y of node centre
            pad_x   = max(3, round(NODE_PAD * 0.5))
            pad_y   = max(3, round(NODE_PAD * 0.5))
            avail_w = NW - 2 * pad_x
            avail_h = NH - 2 * pad_y

            if is_u:
                badge_h   = FONT_BADGE + 4
                txt_avail = avail_h - badge_h - 2
                txt_cy    = node_cy + (badge_h + 2) / 2   # push text up
                _fit_text_in_box(c, lines,
                                 px + NW / 2, txt_cy,
                                 avail_w, txt_avail,
                                 FONT_NODE, _hex(t["font"]))
                # Red UNUSED badge
                bw  = min(NW - 10, round(NW * 0.7))
                bx2 = px + (NW - bw) / 2
                by2 = py - NH + pad_y
                c.setFillColor(HexColor("#FF0000"))
                c.roundRect(bx2, by2, bw, badge_h, 2, fill=1, stroke=0)
                c.setFillColor(white)
                c.setFont("Helvetica-Bold", FONT_BADGE)
                c.drawCentredString(px + NW / 2, by2 + 2, "UNUSED")
            else:
                _fit_text_in_box(c, lines,
                                 px + NW / 2, node_cy,
                                 avail_w, avail_h,
                                 FONT_NODE, _hex(t["font"]))

    # ── Edges ────────────────────────────────────────────────────────────────
    edge_color  = HexColor("#555555")
    label_fill  = HexColor("#f5f5f5")
    label_border= HexColor("#cccccc")
    label_text  = HexColor("#333333")
    label_rects = []   # (lx, ly, lw, lh) of every placed label — for stagger

    # ── Bidirectional horizontal-edge separation ──────────────────────────────
    # When two edges connect the same pair of nodes in opposite directions AND
    # both land on the same horizontal (same row, adjacent column), they would
    # be drawn on top of each other.  Offset one upward and one downward by
    # NH/5 so they get distinct lines and distinct label positions.
    _all_edge_pairs = {(e["from"], e["to"]) for e in cfg["edges"]}
    _bidir_offset   = {}
    _bidir_delta    = NH / 5
    for edge in cfg["edges"]:
        s, d = edge["from"], edge["to"]
        if (d, s) not in _all_edge_pairs:
            continue
        sc_e = col_of[node_to_layer[s]]
        dc_e = col_of[node_to_layer[d]]
        sr_e = layer_nodes[node_to_layer[s]].index(s)
        dr_e = layer_nodes[node_to_layer[d]].index(d)
        if abs(sc_e - dc_e) == 1 and sr_e == dr_e:
            # Same-row adjacent pair: forward goes UP, backward goes DOWN
            if sc_e < dc_e:
                _bidir_offset[(s, d)] = -_bidir_delta   # forward → above centre
            else:
                _bidir_offset[(s, d)] = +_bidir_delta   # backward → below centre

    # First line of each node's display label, used in continuation markers
    _node_label = {
        n["id"]: _clean_label(n.get("label", n["id"])).split("\n")[0].strip()
        for layer in cfg["layers"]
        for n in layer.get("nodes", [])
    }

    for edge in cfg["edges"]:
        src, dst = edge["from"], edge["to"]
        src_col  = col_of[node_to_layer[src]]
        dst_col  = col_of[node_to_layer[dst]]

        src_on_page = src_col in cols
        dst_on_page = dst_col in cols

        if not src_on_page and not dst_on_page:
            continue   # nothing to draw on this page

        # Find which page has the destination (for continuation label)
        dst_page = next((i for i, pg in enumerate(page_groups) if dst_col in pg), None)

        v_off      = _bidir_offset.get((src, dst), 0.0)
        pts_canvas = compute_routing(src, dst, abs_pos, node_to_layer,
                                     col_of, layer_nodes, edge.get("label", ""),
                                     vert_offset=v_off)

        # Convert canvas points → PDF coords (applying gutter x_offset)
        pts_pdf = [_pxy(px, py) for px, py in pts_canvas]

        # Clip polyline to the page's x range using proper segment intersection.
        # This prevents lines from entering the page margins or continuing off the
        # edge of the page when an edge spans two different page groups.
        # Left clip: use MARGIN (not MARGIN+x_offset) so incoming corridor
        # segments visible in the gutter zone are drawn — they serve as the
        # visual continuation trail from the previous page.
        left_clip  = MARGIN
        right_clip = PAGE_W - MARGIN

        def _lerp(a, b, t):
            return (a[0] + t * (b[0] - a[0]), a[1] + t * (b[1] - a[1]))

        def _clip_segment(p0, p1):
            """Clip segment P0→P1 to x-range [left_clip, right_clip].
            Returns (ca, cb, ok). ok=False means segment is entirely outside."""
            x0, y0 = p0
            x1, y1 = p1
            dx = x1 - x0
            # Reject if both points are strictly on the same outside side
            if x0 < left_clip and x1 < left_clip:
                return p0, p1, False
            if x0 > right_clip and x1 > right_clip:
                return p0, p1, False
            # Both inside (common case) — fast path
            if left_clip <= x0 <= right_clip and left_clip <= x1 <= right_clip:
                return p0, p1, True
            # At least one endpoint outside — compute entry/exit t parameters
            t_min, t_max = 0.0, 1.0
            if abs(dx) > 1e-9:
                tL = (left_clip  - x0) / dx
                tR = (right_clip - x0) / dx
                t_min = max(t_min, min(tL, tR))
                t_max = min(t_max, max(tL, tR))
            if t_min > t_max:
                return p0, p1, False
            return _lerp(p0, p1, t_min), _lerp(p0, p1, t_max), True

        clipped = []
        for i in range(len(pts_pdf) - 1):
            a, b, ok = _clip_segment(pts_pdf[i], pts_pdf[i + 1])
            if not ok:
                continue
            if not clipped:
                clipped.append(a)
            elif math.hypot(clipped[-1][0] - a[0], clipped[-1][1] - a[1]) > 0.5:
                clipped.append(a)   # gap — shouldn't happen in our routes
            clipped.append(b)

        if len(clipped) < 2:
            continue

        cross_page = not dst_on_page or not src_on_page

        # Draw the polyline
        _draw_polyline(c, clipped, edge_color, width=0.75, dashed=cross_page)

        # Arrowhead at last visible point (only if destination is on this page)
        if dst_on_page and len(clipped) >= 2:
            _arrowhead(c, clipped[-2][0], clipped[-2][1],
                       clipped[-1][0], clipped[-1][1], edge_color)

        # ── Edge label ──────────────────────────────────────────────────────────
        # Label placement strategy (mirrors draw.io behaviour):
        #   • Multi-column edges  → midpoint of the CORRIDOR HORIZONTAL segment
        #     (the segment that lies at Y_TOP, above the swimlanes).  Different
        #     edges cover different horizontal spans so their labels end up at
        #     different x positions and rarely collide.
        #   • Adjacent-column / same-column → midpoint of the gap segment.
        #
        # If two labels would overlap, the later one is shifted upward until
        # clear (tracked in `label_rects` which persists for this page).
        raw_lbl = edge.get("label", "").replace("\\n", "\n").replace("\\\\n", "\n")
        if raw_lbl.strip():
            sc_e = col_of[node_to_layer[src]]
            dc_e = col_of[node_to_layer[dst]]
            is_multi = abs(sc_e - dc_e) > 1

            # For corridor (multi-column) edges that span page boundaries, only
            # render the label on the destination page.  On source-only pages the
            # partial dashed line gets a "→ pg N" continuation marker instead;
            # placing the label there risks it landing on the swimlane boundary.
            if is_multi and not dst_on_page:
                raw_lbl = ""

        if raw_lbl.strip():
            sc_e = col_of[node_to_layer[src]]
            dc_e = col_of[node_to_layer[dst]]
            is_multi = abs(sc_e - dc_e) > 1

            if is_multi:
                # Corridor horizontal: segment between the two gap-mid x values
                # at Y_TOP.  In canvas coords: (g_src, Y_TOP) → (g_dst, Y_TOP).
                # Convert both to PDF and take midpoint.
                Y_TOP_c = -(TOP_CORR_H - 22)
                if sc_e < dc_e:
                    gx_a = _gap_mid(sc_e)
                    gx_b = _gap_mid(dc_e - 1)
                else:
                    gx_a = _gap_mid(sc_e - 1)
                    gx_b = _gap_mid(dc_e)
                pa = _pxy(gx_a, Y_TOP_c)
                pb = _pxy(gx_b, Y_TOP_c)
                lbl_cx = (pa[0] + pb[0]) / 2
                lbl_cy = pa[1]          # same y for both (horizontal segment)
                # Fall back if ideal corridor midpoint is off this page.
                # Prefer the HORIZONTAL corridor segment at Y_TOP level so the
                # label lands in the corridor zone, not on the vertical descent leg
                # (which would place it inside the swimlane header area).
                if not (left_clip + 5 <= lbl_cx <= right_clip - 5):
                    Y_TOP_c_pdf = diagram_top - Y_TOP_c   # PDF y of corridor
                    corr_seg = None
                    for _k in range(len(clipped) - 1):
                        if (abs(clipped[_k][1]     - Y_TOP_c_pdf) < 3 and
                                abs(clipped[_k + 1][1] - Y_TOP_c_pdf) < 3):
                            corr_seg = _k
                            break
                    if corr_seg is not None:
                        lbl_cx = (clipped[corr_seg][0] + clipped[corr_seg + 1][0]) / 2
                        lbl_cy = Y_TOP_c_pdf
                    else:
                        mid_idx = len(clipped) // 2
                        lbl_cx  = (clipped[mid_idx - 1][0] + clipped[mid_idx][0]) / 2
                        lbl_cy  = (clipped[mid_idx - 1][1] + clipped[mid_idx][1]) / 2
            else:
                # For adjacent/same-column: midpoint of the middle segment
                mid_idx = len(clipped) // 2
                lbl_cx  = (clipped[mid_idx - 1][0] + clipped[mid_idx][0]) / 2
                lbl_cy  = (clipped[mid_idx - 1][1] + clipped[mid_idx][1]) / 2

            lbl_lines = [l for l in raw_lbl.split("\n") if l.strip()]

            # Auto-wrap individual lines that are too wide for the column gap so
            # that gap-area labels (adjacent / same-column) never overflow into the
            # neighbouring swimlane.  Corridor labels (is_multi) already have ample
            # horizontal space and don't need wrapping.
            if not is_multi:
                avail_label_w = COL_GAP - 8
                wrapped = []
                for line in lbl_lines:
                    if c.stringWidth(line, "Helvetica", FONT_EDGE) <= avail_label_w:
                        wrapped.append(line)
                    else:
                        words = line.split()
                        cur = ""
                        for word in words:
                            test = (cur + " " + word).strip()
                            if c.stringWidth(test, "Helvetica", FONT_EDGE) <= avail_label_w:
                                cur = test
                            else:
                                if cur:
                                    wrapped.append(cur)
                                cur = word
                        if cur:
                            wrapped.append(cur)
                lbl_lines = wrapped if wrapped else lbl_lines

            max_chars = max(len(l) for l in lbl_lines)
            lw = max_chars * FONT_EDGE * 0.62 + 10
            lh = len(lbl_lines) * FONT_EDGE * 1.35 + 6

            # Clamp centre-x so the pill stays in the right zone.
            # Labels for edges arriving from a previous page may sit in the gutter
            # [MARGIN … MARGIN+x_offset], but their RIGHT edge must not enter the
            # first swimlane (kept ≥6 pt clear).  All other labels stay in the
            # diagram area [MARGIN+x_offset … right_clip].
            if not src_on_page and dst_on_page:
                left_bound  = MARGIN + lw / 2 + 2
                right_bound = MARGIN + x_offset - lw / 2 - 6   # clear of swimlane
            else:
                left_bound  = MARGIN + x_offset + lw / 2 + 2
                right_bound = right_clip - lw / 2 - 2
            lbl_cx = max(left_bound, min(right_bound, lbl_cx))

            # For horizontal single-segment labels, offset the pill so the
            # arrowhead doesn't run through the text:
            #   • Forward edges  (sc_e < dc_e): pill sits ABOVE the line
            #   • Backward edges (sc_e > dc_e): pill sits BELOW the line
            # This gives each direction its own unambiguous vertical zone and
            # prevents the stagger logic from pushing bidirectional pair labels
            # up into the top corridor.
            mid_idx_chk = len(clipped) // 2
            seg_is_horiz = (abs(clipped[mid_idx_chk][1] -
                                clipped[mid_idx_chk - 1][1]) < 1)
            if seg_is_horiz:
                if sc_e > dc_e:
                    lbl_cy = lbl_cy - lh / 2 - 3   # backward: pill top 3pt below line
                else:
                    lbl_cy = lbl_cy + lh / 2 + 3   # forward:  pill bottom 3pt above line

            # Vertical stagger: if two labels still overlap, push the later one
            # in the direction that keeps it inside the diagram area.
            lx = lbl_cx - lw / 2
            ly = lbl_cy - lh / 2
            for _rect in label_rects:
                rx, ry, rw, rh = _rect
                if lx < rx + rw and lx + lw > rx and ly < ry + rh and ly + lh > ry:
                    up_ly   = ry + rh + 3          # candidate: push above prev rect
                    down_ly = ry - lh - 3          # candidate: push below prev rect
                    # Prefer pushing up unless that would enter the corridor
                    if up_ly + lh <= diagram_top:
                        ly = up_ly
                    else:
                        ly = down_ly
                    lbl_cy = ly + lh / 2
            label_rects.append((lx, ly, lw, lh))

            # Pill background
            c.setFillColor(label_fill)
            c.setStrokeColor(label_border)
            c.setLineWidth(0.4)
            c.roundRect(lx, ly, lw, lh, 3, fill=1, stroke=1)

            # Centred text via the proven helper
            _draw_text_block(c, lbl_lines, lbl_cx, ly + lh / 2,
                             None, FONT_EDGE, label_text)

        # Continuation label for cross-page edges: "<destination node name> →"
        # Font is 4 steps smaller than the edge font.  The label is placed
        # above or below the exit line depending on where there's clear space —
        # checked against every previously placed label pill (label_rects) and
        # the page header zone.
        if cross_page and dst_page is not None and dst_page != page_idx:
            last      = clipped[-1]
            dst_name  = _node_label.get(dst, dst)
            cont_lbl  = f"{dst_name} →"
            cont_font = max(5, FONT_EDGE - 4)
            face_cont = "Helvetica-Oblique"
            c.setFont(face_cont, cont_font)
            cl_w  = c.stringWidth(cont_lbl, face_cont, cont_font)
            cl_h  = cont_font * 1.2
            cl_rx = last[0] - 2          # right edge of text
            cl_lx = cl_rx - cl_w         # left  edge of text
            gap   = 2

            def _cont_overlaps(ly):
                """True if rect (cl_lx, ly, cl_w, cl_h) overlaps any label or header."""
                if ly + cl_h > PAGE_H - MARGIN - HEADER_H:
                    return True
                if ly < MARGIN:
                    return True
                for rx, ry, rw, rh in label_rects:
                    if cl_lx < rx + rw and cl_lx + cl_w > rx \
                            and ly < ry + rh and ly + cl_h > ry:
                        return True
                return False

            # Prefer above; fall back to below; if both clash, stay above
            ly_above = last[1] + gap
            ly_below = last[1] - cl_h - gap
            if not _cont_overlaps(ly_above):
                chosen_ly = ly_above
            elif not _cont_overlaps(ly_below):
                chosen_ly = ly_below
            else:
                chosen_ly = ly_above   # least-bad fallback

            c.setFillColor(HexColor("#555555"))
            c.setFont(face_cont, cont_font)
            c.drawRightString(cl_rx, chosen_ly, cont_lbl)
            label_rects.append((cl_lx, chosen_ly, cl_w, cl_h))


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    config_path = sys.argv[1]
    out_path    = sys.argv[2] if len(sys.argv) >= 3 else \
                  str(Path(config_path).with_suffix(".pdf"))

    with open(config_path, encoding="utf-8") as f:
        cfg = json.load(f)

    n_cols  = len(cfg["layers"])
    avail_w = PAGE_W - 2 * MARGIN   # 720 pt for letter landscape

    # ── Use full-size layout (k = 1.0) and let columns flow across pages ──────
    # Only scale down if even 1 column per page would produce unreadable text
    # (an extreme edge-case for very wide diagrams).  The user's intent is clear:
    # widen columns, move rightmost columns to the next page rather than compress.
    chosen_k = 1.0
    if _B_FONT_NODE * chosen_k < 7:
        # Pathological: find the smallest k where font ≥ 7 pt with 1 col/page
        chosen_k = 7 / _B_FONT_NODE

    _apply_scale(chosen_k)

    # ── Compute layout (uses updated globals) ─────────────────────────────────
    abs_pos, swimlane_geom, node_to_layer, col_of, layer_nodes, layer_meta = \
        compute_layout(cfg)

    # ── Group columns per page ────────────────────────────────────────────────
    # Page 1 uses the full available width.
    # Pages 2+ reserve CONT_GUTTER on the left for incoming cross-page edge
    # continuations and "← from pg N" markers, so they fit fewer columns.
    # If adding the gutter would overflow, the rightmost column flows to the
    # next page automatically.
    cols_per_pg_full   = max(1, int(avail_w // COL_STRIDE))
    cols_per_pg_gutter = max(1, int((avail_w - CONT_GUTTER) // COL_STRIDE))

    page_groups = [list(range(0, min(cols_per_pg_full, n_cols)))]
    col_start   = cols_per_pg_full
    while col_start < n_cols:
        end = min(col_start + cols_per_pg_gutter, n_cols)
        page_groups.append(list(range(col_start, end)))
        col_start = end

    print(f"Scale: {chosen_k:.3f}  |  "
          f"pg1: {cols_per_pg_full} col(s), pg2+: {cols_per_pg_gutter} col(s)  |  "
          f"{len(page_groups)} page(s)  |  fonts: node={FONT_NODE}pt  edge={FONT_EDGE}pt")

    # ── Create PDF ────────────────────────────────────────────────────────────
    c = rlcanvas.Canvas(out_path, pagesize=(PAGE_W, PAGE_H))
    c.setTitle(cfg.get("title", "Architecture"))
    c.setAuthor("architecture-graph skill")

    # Reset stagger state once (shared across pages)
    _skip_r_state.clear()
    _up_l_state.clear()

    for page_idx in range(len(page_groups)):
        x_off = 0 if page_idx == 0 else CONT_GUTTER
        _render_page(c, cfg, page_idx, page_groups, abs_pos, swimlane_geom,
                     node_to_layer, col_of, layer_nodes, layer_meta,
                     x_offset=x_off)
        c.showPage()

    c.save()
    print(f"Written: {out_path}  ({len(page_groups)} page(s))")


if __name__ == "__main__":
    main()
